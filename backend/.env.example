# Copiar este archivo a backend/.env y completar los valores.

# === Base de datos ===
# En Docker, docker-compose ya setea DB_HOST=db y estas credenciales.
# Estos valores son para correr el backend LOCAL (sin Docker).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=DB_ProyectoFinal_IDS
DB_USER=root
DB_PASSWORD=ids-local-dev

# === JWT (firma de la sesion) ===
SECRET_KEY=dev-secret-cambiar

# === Firma de los links de asistencia ===
ATTENDANCE_SECRET=dev-attendance-secret-cambiar

# === Envio de mails (Gmail App Password de 16 caracteres) ===
# 1) Activa la verificacion en 2 pasos en la cuenta de Google.
# 2) Seguridad -> Contrasenas de aplicaciones -> genera una.
# 3) Pega los 16 caracteres (sin espacios) en EMAIL_PASS y el mail en EMAIL_USER.
# Si lo dejas vacio, la app funciona igual pero no manda mails.
EMAIL_USER=
EMAIL_PASS=

# === Slack (opcional) ===
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
