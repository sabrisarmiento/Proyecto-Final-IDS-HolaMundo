# Copiar este archivo a backend/.env y completar los valores.

# base de datos
DB_HOST=db
DB_PORT=3306
DB_NAME=DB_ProyectoFinal_IDS
DB_USER=root
DB_PASSWORD=ids-local-dev

# jwt
SECRET_KEY=cambia_esto_por_una_clave_secreta_segura
JWT_SECRET_KEY=
JWT_EXPIRES_MINUTES=360

# asistencia

# usamos una cuenta de gmail con app password
# pasos para obtener el app password:

# 1) ir a administra tu cuenta de Google 
# 2) activar la 2fa en tu cuenta de Google en caso de que no este activa
# 3) en el buscador buscar "app password" o "contraseñas de aplicaciones" 
# 4) poner un nombre y tocar en "Crear" para generar contraseña
# 5) pegar el resultado de 16 caracteres en EMAIL_PASS y la direccion de mail de tu cuenta en EMAIL_USER
# Si lo dejas vacio, la app funciona igual pero no manda mails.
EMAIL_USER=
EMAIL_PASS=xxxx xxxx xxxx xxxx
ATTENDANCE_SECRET=

# slack de avisos
FERNET_KEY=