# asistencia QR
# usamos una cuenta de gmail con app password
# pasos para obtener el app password:
# 1) ir a administra tu cuenta de Google 
# 1) activar la 2fa en tu cuenta de Google en caso de que no este activa
# 2) en el buscador buscar "app password" o "contraseñas de aplicaciones" 
# 3) poner un nombre y tocar en "Crear" para generar contraseña
# 4) pegar el resultado de 16 caracteres en EMAIL_PASS y la direccion de mail de tu cuenta en EMAIL_USER
EMAIL_USER=
EMAIL_PASS=xxxx xxxx xxxx xxxx

# slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:5000/slack/oauth/callback